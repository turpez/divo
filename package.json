{
  "name": "divo",
  "version": "1.0.29",
  "description": "Divo Browser",
  "author": "Divh",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.divh.divo",
    "productName": "Divo",
    "copyright": "Divh",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "protocols": [
        { "name": "Divo Browser", "schemes": ["http", "https"] }
      ],
      "fileAssociations": [
        { "ext": "html",  "name": "Divo HTML Document", "description": "Ouvrir avec Divo" },
        { "ext": "htm",   "name": "Divo HTML Document", "description": "Ouvrir avec Divo" },
        { "ext": "xhtml", "name": "Divo HTML Document", "description": "Ouvrir avec Divo" },
        { "ext": "shtml", "name": "Divo HTML Document", "description": "Ouvrir avec Divo" },
        { "ext": "xht",   "name": "Divo HTML Document", "description": "Ouvrir avec Divo" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Divo"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    }
  }
}
